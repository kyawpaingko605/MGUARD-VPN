<?xml version="1.0" encoding="utf-8"?>
<ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".MainActivity">

    <!-- Header Bar -->
    <RelativeLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/bg_card"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MGuard"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:background="@color/teal_950"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:text="VPN"
                    android:textColor="@color/teal_400"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Security &amp; Ad Rewards"
                android:textColor="@color/text_muted"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/headerTimeContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@color/bg_dark"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@android:drawable/ic_menu_recent_history"
                app:tint="@color/amber_400" />

            <TextView
                android:id="@+id/txtHeaderTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="02:00:00"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </RelativeLayout>

    <FrameLayout
        android:id="@+id/contentFrame"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomNav"
        app:layout_constraintTop_toBottomOf="@+id/headerBar">

        <!-- TAB 1: VPN DASHBOARD -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/layoutVpnTab"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/bg_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="သင်၏လက်ရှိ IP လိပ်စာ"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/txtVpnIp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="103.115.112.56 (ရန်ကုန်, မြန်မာ)"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <FrameLayout
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_gravity="center"
                    android:layout_marginVertical="36dp">

                    <View
                        android:id="@+id/vpnPulseRing"
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:layout_gravity="center"
                        android:background="@android:drawable/dialog_holo_dark_frame" />

                    <LinearLayout
                        android:id="@+id/btnVpnSwitch"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:layout_gravity="center"
                        android:background="@color/bg_card"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <ImageView
                            android:id="@+id/imgVpnPower"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@android:drawable/ic_menu_compass"
                            app:tint="@color/text_muted" />

                        <TextView
                            android:id="@+id/txtVpnPowerStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="မချိတ်ဆက်ပါ"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtVpnClickToConnect"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ချိတ်ဆက်ရန် နှိပ်ပါ"
                            android:textColor="@color/teal_400"
                            android:textSize="10sp" />
                    </LinearLayout>
                </FrameLayout>

                <TextView
                    android:id="@+id/txtConnectionTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginBottom="24dp"
                    android:text="ချိတ်ဆက်ချိန်: 00:00:00"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@color/bg_card"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DOWNLOAD"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtDownloadSpeed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0.0 Mbps"
                            android:textColor="@color/teal_400"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:background="@color/bg_card"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="UPLOAD"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtUploadSpeed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0.0 Mbps"
                            android:textColor="@color/amber_400"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnServerSelect"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@color/bg_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_mylocation"
                        app:tint="@color/teal_400" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ချိတ်ဆက်မည့်ဆာဗာ"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/txtCurrentServer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Singapore - Free High Speed"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ပြောင်းရန် >"
                        android:textColor="@color/teal_400"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- TAB 2: AD REWARDS TAB -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/layoutEarnTab"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/bg_card"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_recent_history"
                        app:tint="@color/amber_400" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="VPN ချိတ်ဆက်ခွင့်ကျန်ရှိချိန်"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtTabRemainingTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="02 နာရီ : 00 မိနစ် : 00 စက္ကန့်"
                        android:textColor="@android:color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/progressTimeBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="16dp"
                        android:max="100"
                        android:progress="16" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="ကြော်ငြာကြည့်ပြီး အချိန်တိုးယူပါ"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/adCampaignsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- TAB 3: PREMIUM & DEV TAB -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/layoutPremiumTab"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/bg_card"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="အသုံးပြုသူအမျိုးအစား"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/txtPremiumUserStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Free User"
                            android:textColor="@color/amber_400"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnToggleDevMode"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dev Mode ⚙️"
                        android:textColor="@color/text_muted" />
                </LinearLayout>

                <!-- Normal Purchase Section -->
                <LinearLayout
                    android:id="@+id/layoutUserPurchaseView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Premium ဆာဗာများ အသုံးပြုရန် ဝယ်ယူပါ"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <!-- Payment Details Card -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@color/bg_card"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="KBZPay Account Details"
                            android:textColor="@color/teal_400"
                            android:textStyle="bold" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp">

                            <TextView
                                android:id="@+id/txtKPayNum"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="09456789123 (U Aung Hein)"
                                android:textColor="@android:color/white" />

                            <Button
                                android:id="@+id/btnCopyKPay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="Copy" />
                        </RelativeLayout>
                    </LinearLayout>

                    <!-- Submission Form -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@color/bg_card"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <EditText
                            android:id="@+id/editTxId"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Transaction TxID (6 characters)"
                            android:textColorHint="@color/text_muted" />

                        <EditText
                            android:id="@+id/editUserPhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Your Phone Number"
                            android:textColorHint="@color/text_muted" />

                        <Button
                            android:id="@+id/btnSubmitTx"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="အတည်ပြုချက် တင်သွင်းမည်" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Dev Admin Controls Panel -->
                <LinearLayout
                    android:id="@+id/layoutDevAdminView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Developer Dashboard ⚙️"
                        android:textColor="@color/teal_400"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <TextView
                            android:id="@+id/txtDevTotalViews"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total Views: 148"
                            android:textColor="@android:color/white" />

                        <TextView
                            android:id="@+id/txtDevTotalRevenue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Revenue: 45,000 MMK"
                            android:textColor="@color/green_500" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutDevPendingSubmissions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </FrameLayout>

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/bg_card"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/navVpn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imgNavVpn"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_lock_lock" />

            <TextView
                android:id="@+id/txtNavVpn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VPN" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navEarn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imgNavEarn"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_recent_history" />

            <TextView
                android:id="@+id/txtNavEarn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="အချိန်တိုးရန်" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPremium"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imgNavPremium"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/star_big_off" />

            <TextView
                android:id="@+id/txtNavPremium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Premium &amp; Dev" />
        </LinearLayout>
    </LinearLayout>
</ConstraintLayout>

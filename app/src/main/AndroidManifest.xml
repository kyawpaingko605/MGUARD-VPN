<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.mguard.vpn">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- Android Foreground Service မောင်းနှင်ရန် Permission -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    
    <!-- 🛡️ Android 14+ (API 34+) တွင် VPN မောင်းနှင်ရန် အဓိက လိုအပ်သော Permission (မဖြစ်မနေ ထည့်ရပါမည်) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_VPN" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="MGuard VPN"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MGuardVPN">
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 🛠️ LocalVpnService အား Android 14+ ပေါ်တွင် အလုပ်လုပ်နိုင်ရန် ပြင်ဆင်ထားမှု -->
        <service
            android:name=".LocalVpnService"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:foregroundServiceType="vpn"
            android:exported="false">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>
    </application>

</manifest>

<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- Android Foreground Service အခြေခံ Permission -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    
    <!-- 🚨 connectedDevice သုံးထားသည့်အတွက် Android 14+ ပေါ်တွင် Crash မဖြစ်စေရန် ဤ Permission မဖြစ်မနေ ထည့်ရပါမည် -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="MGuard VPN"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MGuardVPN">
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 🛠️ AAPT linking အောင်မြင်စေရန် foregroundServiceType ကို connectedDevice ဟု သတ်မှတ်ခြင်း -->
        <service
            android:name=".LocalVpnService"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:foregroundServiceType="connectedDevice"
            android:exported="false">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>
    </application>

</manifest>
